# Copy this file to `.env` and adjust values to point at a non-default
# OpenObserve instance. `.env` is gitignored — never commit it.
#
# Precedence: real shell env vars > .env > built-in defaults in helpers/config.py
# The built-in defaults match the assignment's published values, so you can
# run `pytest` with no .env at all against a local OpenObserve.

OO_BASE_URL=http://localhost:5080
OO_ORG=default
OO_USER=root@example.com
OO_PASSWORD=Complexpass#123
